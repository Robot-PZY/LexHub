{
  "title": "LexHub 演示基准指标",
  "scenario": "法律任务端到端演示",
  "metrics": [
    {
      "id": "task_time",
      "label": "单任务处理时间",
      "unit": "min",
      "direction": "lower_better",
      "traditional": 45,
      "lexhub": 12,
      "note": "覆盖材料接入、事实梳理、法规检索和初稿形成"
    },
    {
      "id": "traceability",
      "label": "引用可追溯率",
      "unit": "%",
      "direction": "higher_better",
      "traditional": 60,
      "lexhub": 88,
      "note": "是否能定位到法规、案例、模板或来源摘要"
    },
    {
      "id": "reviewability",
      "label": "过程复核覆盖",
      "unit": "%",
      "direction": "higher_better",
      "traditional": 35,
      "lexhub": 100,
      "note": "是否保留任务阶段、工具调用和回放记录"
    },
    {
      "id": "delivery",
      "label": "文书初稿形成",
      "unit": "%",
      "direction": "higher_better",
      "traditional": 45,
      "lexhub": 90,
      "note": "是否能形成结构化报告或可导出文书"
    },
    {
      "id": "tool_visibility",
      "label": "工具调用可见性",
      "unit": "%",
      "direction": "higher_better",
      "traditional": 20,
      "lexhub": 92,
      "note": "是否能查看搜索、法规检索、文档处理等调用轨迹"
    }
  ],
  "evidence_matrix": [
    ["业务场景分析", "test/", "README.md", "technical report"],
