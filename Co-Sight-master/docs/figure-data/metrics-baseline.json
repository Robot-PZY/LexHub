    ["DAG 编排", "legal-workflow.json", "DagExecutionPanel", "replay"],
    ["工具集成", "legal_search_toolkit.py", "services/legal_kb", "tool trace"],
    ["可信安全", "audit_log.py", "execution_snapshot.py", "replay"],
    ["文书交付", "document_export.py", "Workspace result page", "DOCX/PDF export"]
  ],
  "legal_sources": [
    ["法律法规", "国家法律法规数据库", "法律、行政法规、监察法规、司法解释、地方性法规等", "法规条文与效力状态"],
    ["行政法规", "国家行政法规库", "现行有效行政法规及历史文本", "行政监管与合规依据"],
    ["指导案例", "最高人民法院指导性案例", "裁判规则、争议焦点、裁判要旨", "类案参考与裁判尺度"],
    ["裁判文书", "中国裁判文书网", "公开裁判文书、案由、法院、裁判理由", "案例检索与事实比对"],
    ["检察案例", "最高人民检察院指导性案例", "检察履职、监督规则、典型案例", "刑事、公益诉讼和合规参考"],
